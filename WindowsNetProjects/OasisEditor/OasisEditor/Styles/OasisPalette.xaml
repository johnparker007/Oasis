<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Central editor palette sampled from the supplied Oasis Editor screenshot. -->
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#FF25282C" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF2A2D31" />
    <SolidColorBrush x:Key="InspectorBackgroundBrush" Color="#FF2D3034" />
    <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="#FF303338" />
    <SolidColorBrush x:Key="WorkspaceBackgroundBrush" Color="#FF4A4E53" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#FF3A3E44" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#FF454A51" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF4F4F4" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFD7D9DC" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FFA6ABB1" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#FF3B3F45" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FF50555C" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF555A62" />
    <SolidColorBrush x:Key="DisabledBrush" Color="#FF6B7077" />
</ResourceDictionary>
